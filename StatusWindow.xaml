<Window x:Class="Peeklet.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Peeklet"
        Icon="Assets/peeklet-icon.ico"
        Width="460"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F7F3EA"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown">
  <Border Margin="18"
          Padding="24"
          Background="#FFFDF8"
          BorderBrush="#D7CBB2"
          BorderThickness="1"
          CornerRadius="18">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel>
        <TextBlock Text="Peeklet 正在后台运行"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2F2A22" />
        <TextBlock Margin="0 8 0 0"
                   FontSize="14"
                   LineHeight="20"
                   TextWrapping="Wrap"
                   Foreground="#5C5244"
                   Text="在资源管理器中选中文件后，按空格键即可快速预览。" />
        <TextBlock Margin="0 8 0 0"
                   FontSize="14"
                   LineHeight="20"
                   TextWrapping="Wrap"
                   Foreground="#5C5244"
                   Text="预览打开后，可按左右方向键切换文件，按 Esc 关闭预览。" />
      </StackPanel>

      <StackPanel Grid.Row="2"
                  Margin="0 24 0 0"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right">
        <Button Width="108"
                Height="36"
                Padding="12 0"
                Background="#2F6F57"
                Foreground="White"
                BorderThickness="0"
                Click="CloseButton_Click"
                Content="知道了" />
      </StackPanel>
    </Grid>
  </Border>
</Window>